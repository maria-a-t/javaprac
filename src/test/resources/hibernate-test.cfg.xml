<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:mem:internet_shop_test;MODE=PostgreSQL;DB_CLOSE_DELAY=-1</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>
        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hibernate.show_sql">false</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.hbm2ddl.auto">create-drop</property>

        <mapping class="ru.msu.internetshop.model.Category"/>
        <mapping class="ru.msu.internetshop.model.Manufacturer"/>
        <mapping class="ru.msu.internetshop.model.Product"/>
        <mapping class="ru.msu.internetshop.model.ProductAttribute"/>
        <mapping class="ru.msu.internetshop.model.Customer"/>
        <mapping class="ru.msu.internetshop.model.OrderStatus"/>
        <mapping class="ru.msu.internetshop.model.CustomerOrder"/>
        <mapping class="ru.msu.internetshop.model.OrderItem"/>
        <mapping class="ru.msu.internetshop.model.Delivery"/>
    </session-factory>
</hibernate-configuration>
